generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Platform {
  TELEGRAM
  INSTAGRAM
}

enum OrderStatus {
  PENDING
  PROCESSING
  IN_PROGRESS
  COMPLETED
  PARTIAL
  CANCELED
  REFUNDED
  FAILED
}

enum TransactionType {
  TOPUP
  DEDUCT
  REFUND
  REFERRAL
  ADMIN_ADJUST
  PROMO
}

enum PaymentMethod {
  CLICK
  PAYME
  HUMO
  BANK
  CRYPTO
  ADMIN
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NotificationTarget {
  ALL
  USER
  ROLE
}

model User {
  id           String   @id @default(cuid())
  telegramId   BigInt   @unique
  username     String?
  firstName    String?
  lastName     String?
  phone        String?
  password     String?
  balance      Decimal  @default(0) @db.Decimal(12, 2)
  role         UserRole @default(USER)
  language     String   @default("uz")
  isBlocked    Boolean  @default(false)
  referralCode String   @unique @default(cuid())
  referredById String?
  referredBy   User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[]   @relation("Referrals")

  orders         Order[]
  transactions   Transaction[]
  payments       Payment[]
  supportTickets SupportTicket[]
  notifications  UserNotification[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([telegramId])
  @@index([referralCode])
  @@index([referredById])
  @@index([createdAt])
}

model Category {
  id        String    @id @default(cuid())
  name      Json // { uz: "...", ru: "...", en: "..." }
  slug      String    @unique
  platform  Platform
  icon      String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  services  Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([platform])
  @@index([sortOrder])
}

model Service {
  id            String   @id @default(cuid())
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  name          Json // { uz: "...", ru: "...", en: "..." }
  description   Json? // { uz: "...", ru: "...", en: "..." }
  minQuantity   Int
  maxQuantity   Int
  pricePerUnit  Decimal  @db.Decimal(12, 6)
  isActive      Boolean  @default(true)
  isAutoService Boolean  @default(false)
  sortOrder     Int      @default(0)
  dripFeed      Boolean  @default(false)

  providerMappings ServiceProviderMapping[]
  orders           Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([isActive])
}

model Provider {
  id          String    @id @default(cuid())
  name        String
  apiUrl      String
  apiKey      String
  balance     Decimal   @default(0) @db.Decimal(12, 2)
  isActive    Boolean   @default(true)
  priority    Int       @default(0)
  lastSyncAt  DateTime?
  description String?

  services ProviderService[]
  orders   Order[]
  mappings ServiceProviderMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model ProviderService {
  id                String   @id @default(cuid())
  providerId        String
  provider          Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  externalServiceId String
  name              String
  category          String?
  pricePerUnit      Decimal  @db.Decimal(12, 6)
  minQuantity       Int
  maxQuantity       Int
  isActive          Boolean  @default(true)

  mappings ServiceProviderMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, externalServiceId])
  @@index([providerId])
}

model ServiceProviderMapping {
  id                String          @id @default(cuid())
  serviceId         String
  service           Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  providerServiceId String
  providerService   ProviderService @relation(fields: [providerServiceId], references: [id], onDelete: Cascade)
  providerId        String
  provider          Provider        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  priority          Int             @default(0)
  isActive          Boolean         @default(true)

  @@unique([serviceId, providerServiceId])
  @@index([serviceId])
  @@index([providerId])
}

model Order {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  serviceId    String
  service      Service     @relation(fields: [serviceId], references: [id])
  link         String
  quantity     Int
  totalPrice   Decimal     @db.Decimal(12, 2)
  status       OrderStatus @default(PENDING)
  startCount   Int?
  currentCount Int?
  remains      Int?

  providerId       String?
  provider         Provider? @relation(fields: [providerId], references: [id])
  providerOrderId  String?
  providerResponse Json?

  isAutoOrder   Boolean   @default(false)
  autoExpiresAt DateTime?

  dripFeedInterval Int?
  dripFeedQuantity Int?

  refillCount  Int       @default(0)
  lastRefillAt DateTime?

  errorMessage String?
  completedAt  DateTime?
  canceledAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([serviceId])
  @@index([providerId])
  @@index([createdAt])
  @@index([providerOrderId])
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  type         TransactionType
  amount       Decimal         @db.Decimal(12, 2)
  balanceAfter Decimal         @db.Decimal(12, 2)
  description  String?
  metadata     Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Payment {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  amount     Decimal       @db.Decimal(12, 2)
  method     PaymentMethod
  status     PaymentStatus @default(PENDING)
  externalId String?
  metadata   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([externalId])
}

model Notification {
  id         String             @id @default(cuid())
  title      Json // { uz, ru, en }
  message    Json // { uz, ru, en }
  targetType NotificationTarget
  targetId   String?

  recipients UserNotification[]

  createdAt DateTime @default(now())
}

model UserNotification {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id])
  isRead         Boolean      @default(false)
  readAt         DateTime?

  createdAt DateTime @default(now())

  @@unique([userId, notificationId])
  @@index([userId, isRead])
}

model SupportTicket {
  id       String           @id @default(cuid())
  userId   String
  user     User             @relation(fields: [userId], references: [id])
  subject  String
  status   TicketStatus     @default(OPEN)
  messages SupportMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model SupportMessage {
  id       String        @id @default(cuid())
  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id])
  senderId String
  isAdmin  Boolean       @default(false)
  message  String
  fileUrl  String?

  createdAt DateTime @default(now())

  @@index([ticketId])
}

model Setting {
  id          String  @id @default(cuid())
  key         String  @unique
  value       Json
  description String?
  group       String  @default("general")

  updatedAt DateTime @updatedAt

  @@index([group])
}

model Referral {
  id           String  @id @default(cuid())
  referrerId   String
  referredId   String  @unique
  earnedAmount Decimal @default(0) @db.Decimal(12, 2)
  ordersCount  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerId])
}

enum SmsActivationStatus {
  WAITING
  RECEIVED
  EXPIRED
  CANCELED
}

model SmsActivation {
  id        String              @id
  userId    String
  service   String
  country   String
  phone     String
  price     Int
  code      String?
  status    SmsActivationStatus @default(WAITING)
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum PromoType {
  BALANCE_BONUS
  DISCOUNT_PERCENT
  DISCOUNT_FIXED
}

model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  type        PromoType @default(BALANCE_BONUS)
  value       Decimal   @db.Decimal(12, 2)
  amount      Decimal   @default(0) @db.Decimal(12, 2)
  description String?
  maxUses     Int?
  maxUsages   Int?
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)

  usages PromoUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model PromoUsage {
  id      String    @id @default(cuid())
  promoId String
  promo   PromoCode @relation(fields: [promoId], references: [id])
  userId  String
  amount  Decimal?  @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@unique([promoId, userId])
  @@index([userId])
}
